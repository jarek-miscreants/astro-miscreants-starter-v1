---
import Layout from "../layouts/Layout.astro";
import TestComponent from "../components/TestComponent.astro";
import Button from "../components/Button.astro";
import ButtonGroup from "../components/ButtonGroup.astro";
import SectionMain from "../components/SectionMain.astro";
import CardFeatured from "../components/CardFeatured.astro";
import { Icon } from "astro-icon/components";
import featureOne from "../images/feature-1.webp";
import CardIcon from "../components/CardIcon.astro";
import Tabs from "../components/Tabs.astro";
import Accordion from "../components/Accordion.astro";
import FlowSteps from "../components/FlowSteps.astro";
import HubspotForm from "../components/HubspotForm.astro";
import { getCollection, render } from "astro:content";
import LogoMarquee from "../components/LogoMarquee.astro";
import Footer from "../components/Footer.astro";
import SliderBasic from "../components/SliderBasic.astro";
import SliderBasicMap from "../components/SliderBasicMap.astro";
import ComboboxGrouped from "../components/ComboboxGrouped.astro";
import clients from "../data/clients.json";

const faqs = (await getCollection("faq"))
  .filter((faq) => faq.data.page === "homepage")
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Astro Playground">
    <main id="main" class="border-y border-stroke">

      <SectionMain id="hero" padding="none" contentPadding="none" contentClass="items-center text-center relative">
        <div class="relative z-20 flex flex-col items-center gap-2 py-32 md:py-48 px-6">
          <h1 class="h1">Hello World</h1>
          <p class="mt-2 text-xl text-fg-muted">This is a playground for Astro.</p>
          <TestComponent message="Test" />
          <ButtonGroup>
            <Button />
            <Button variant="secondary" label="Get a Demo" />
          </ButtonGroup>
        </div>
      </SectionMain>
      <SectionMain id="clients" padding="none" contentPadding="none" borderTop>
        <div data-accent="tl"></div><div data-accent="tr"></div>
        <div data-accent="bl"></div><div data-accent="br"></div>
        <LogoMarquee>
          {clients.map((client) => (
            <img src={client.logo} alt={client.name} class="w-24 h-16" />
          ))}
        </LogoMarquee>
      </SectionMain>
    
      <SectionMain id="features" paddingTop="sm" paddingBottom="none" contentPadding="none" borderTop>
        <div class="container-large">
          <div class="flex flex-col px-6 gap-4">
            <h2 class="h2">Features</h2>
            <p class="mt-2 text-xl text-fg-muted"></p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-stroke border-y border-stroke">
            <CardFeatured
              border="none"
              class="bg-canvas"
              title="Design content structures your way."
              description="Miscreants gives you full control over content with a streamlined, API-first experience — perfect for teams who want speed without sacrificing flexibility."
            >
              <span slot="eyebrow">Schema Builder</span>
              <Icon slot="icon" name="lucide:layers" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
              <img slot="media" src={featureOne.src} alt="Schema builder screenshot" class="w-full h-auto mt-4 mask-b-from-30% mask-b-to-95%" />
            </CardFeatured>
            <CardFeatured
              border="none"
              class="bg-canvas"
              title="Design content structures your way."
              description="Miscreants gives you full control over content with a streamlined, API-first experience — perfect for teams who want speed without sacrificing flexibility."
            >
              <span slot="eyebrow">Schema Builder</span>
              <Icon slot="icon" name="lucide:database" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
              <img slot="media" src={featureOne.src} alt="Schema builder screenshot" class="w-full h-auto mt-4 mask-b-from-30% mask-b-to-95%" />
            </CardFeatured>
            <CardFeatured
              border="none"
              class="bg-canvas"
              title="Design content structures your way."
              description="Miscreants gives you full control over content with a streamlined, API-first experience — perfect for teams who want speed without sacrificing flexibility."
            >
              <span slot="eyebrow">Schema Builder</span>
              <Icon slot="icon" name="lucide:zap" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
            </CardFeatured>
            <CardFeatured
              border="none"
              class="bg-canvas"
              title="Design content structures your way."
              description="Miscreants gives you full control over content with a streamlined, API-first experience — perfect for teams who want speed without sacrificing flexibility."
            >
              <span slot="eyebrow">Schema Builder</span>
              <Icon slot="icon" name="lucide:settings-2" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
            </CardFeatured>
          </div>
        </div>
      </SectionMain>

      <SectionMain id="icons" padding="none" contentPadding="none">
        <div class="container-large">
          <div class="section-pattern-horizontal w-full py-10"></div>
          <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 border-y border-stroke divide-y lg:divide-y-0">
            <CardIcon header="98.3% uptime" class="bg-canvas">
              <Icon slot="icon" name="lucide:activity" class="w-6 h-6 text-fg-muted mb-4" aria-hidden="true" />
              <p slot="content">Proven reliability across sources with proactive monitoring</p>
            </CardIcon>
            <CardIcon header="Enterprise security" class="bg-canvas">
              <Icon slot="icon" name="lucide:shield-check" class="w-6 h-6 text-fg-muted mb-4" aria-hidden="true" />
              <p slot="content">Encryption at every step with compliance-ready infrastructure</p>
            </CardIcon>
            <CardIcon header="Scalable infrastructure" class="bg-canvas">
              <Icon slot="icon" name="lucide:server" class="w-6 h-6 text-fg-muted mb-4" aria-hidden="true" />
              <p slot="content">Scale your workflow to hundreds of millions of daily fetches</p>
            </CardIcon>
            <CardIcon header="24/7 support" class="bg-canvas">
              <Icon slot="icon" name="lucide:headphones" class="w-6 h-6 text-fg-muted mb-4" aria-hidden="true" />
              <p slot="content">Proven reliability across sources with proactive monitoring</p>
            </CardIcon>
            <CardIcon header="24/7 support" class="bg-canvas">
              <Icon slot="icon" name="lucide:life-buoy" class="w-6 h-6 text-fg-muted mb-4" aria-hidden="true" />
              <p slot="content">Proven reliability across sources with proactive monitoring</p>
            </CardIcon>
          </div>
        </div>
      </SectionMain>

      <SectionMain id="tabs" padding="sm">
        <div data-accent="tl"></div>
        <div data-accent="tr"></div>
        <div data-accent="bl"></div>
        <div data-accent="br"></div>
        <div class="flex flex-col gap-4 mb-6">
          <h2 class="h3">Tabs Component</h2>
          <p class="mt-2 text-fg-muted">Accessible tabs with accordion conversion on mobile.</p>
        </div>

        <Tabs id="demo" convertAccordion slideTabs>
          <div data-tab="button-list" class="flex w-full gap-1 border-b border-stroke [&>*]:flex-1 [&>*]:justify-center">
            <button data-tab="button" class="px-4 py-3 text-sm text-fg-muted border-b-2 border-transparent cursor-pointer transition-colors hover:text-fg [&.is-active]:text-fg [&.is-active]:border-fg">
              <span class="flex items-center gap-2">
                <Icon name="lucide:layers" class="w-4 h-4" aria-hidden="true" />
                Overview
              </span>
            </button>
            <button data-tab="button" class="px-4 py-3 text-sm text-fg-muted border-b-2 border-transparent cursor-pointer transition-colors hover:text-fg [&.is-active]:text-fg [&.is-active]:border-fg">
              <span class="flex items-center gap-2">
                <Icon name="lucide:zap" class="w-4 h-4" aria-hidden="true" />
                Features
              </span>
            </button>
            <button data-tab="button" class="px-4 py-3 text-sm text-fg-muted border-b-2 border-transparent cursor-pointer transition-colors hover:text-fg [&.is-active]:text-fg [&.is-active]:border-fg">
              <span class="flex items-center gap-2">
                <Icon name="lucide:code" class="w-4 h-4" aria-hidden="true" />
                Code
              </span>
            </button>
          </div>
          <div data-tab="panel-list" class="py-8">
            <div data-tab="panel">
              <div class="py-4 md:py-2">
                <h3 class="h4 mb-4">Built for speed</h3>
                <p class="text-fg-muted max-w-2xl">Astro delivers lightning-fast websites by shipping zero JavaScript by default. Only hydrate the components that need interactivity — everything else is pure HTML.</p>
              </div>
            </div>
            <div data-tab="panel">
              <div class="py-4 md:py-2">
                <h3 class="h4 mb-4">Island architecture</h3>
                <p class="text-fg-muted max-w-2xl">Each interactive component is an isolated island. They load independently, so a slow component never blocks the rest of your page from rendering.</p>
              </div>
            </div>
            <div data-tab="panel">
              <div class="py-4 md:py-2">
                <h3 class="h4 mb-4">Framework agnostic</h3>
                <p class="text-fg-muted max-w-2xl">Use React, Vue, Svelte, or Solid — all in the same project. Astro lets you pick the best tool for each component without locking you into a single framework.</p>
              </div>
            </div>
          </div>
        </Tabs>
      </SectionMain>

      <SectionMain id="accordion" padding="sm" borderTop>
        <div class="flex flex-col gap-4 mb-6">
          <h2 class="h3">Accordion Component</h2>
          <p class="mt-2 text-fg-muted">FAQ-style accordion with CSS-only animations.</p>
        </div>

        <Accordion openByDefault={1} class="flex flex-col">
          {faqs.map(async (faq) => {
            const { Content } = await render(faq);
            return (
              <div data-accordion="item" class="bg-canvas border-b border-stroke group">
                <button data-accordion="button" class="flex w-full items-center justify-between py-5 cursor-pointer text-left group-hover:text-fg">
                  <span class="h5">{faq.data.question}</span>
                  <Icon data-accordion="icon" name="lucide:chevron-down" class="w-5 h-5 text-fg-muted shrink-0" aria-hidden="true" />
                </button>
                <div data-accordion="content">
                  <div class="pb-5 text-fg-muted">
                    <Content />
                  </div>
                </div>
              </div>
            );
          })}
        </Accordion>
      </SectionMain>

      <SectionMain id="slider-basic" padding="sm" borderTop>
        <div class="flex flex-col gap-4 mb-6">
          <h2 class="h3">Slider — manual children</h2>
          <p class="mt-2 text-fg-muted">CSS scroll-snap carousel. Drop any components in as direct children.</p>
        </div>

        <SliderBasic mobile={1} mobileLandscape={2} tablet={2} desktop={3} gap="md" ariaLabel="Featured cards">
          <CardFeatured title="Slide one" titleClass="h4" description="Native scroll-snap means swipe and trackpad inertia work for free." class="bg-panel">
            <span slot="eyebrow">Performance</span>
            <Icon slot="icon" name="lucide:zap" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
          </CardFeatured>
          <CardFeatured title="Slide two" titleClass="h4" description="Prev/next, keyboard arrows, and pagination dots are all wired up." class="bg-panel">
            <span slot="eyebrow">Accessibility</span>
            <Icon slot="icon" name="lucide:keyboard" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
          </CardFeatured>
          <CardFeatured title="Slide three" titleClass="h4" description="Zero JS dependencies. Just ~1.5kb of inline script per slider." class="bg-panel">
            <span slot="eyebrow">Lightweight</span>
            <Icon slot="icon" name="lucide:feather" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
          </CardFeatured>
          <CardFeatured title="Slide four" titleClass="h4" description="Each direct child becomes a slide. No wrapper element required." class="bg-panel">
            <span slot="eyebrow">DX</span>
            <Icon slot="icon" name="lucide:wrench" class="w-6 h-6 text-fg-muted" aria-hidden="true" />
          </CardFeatured>
        </SliderBasic>
      </SectionMain>

      <SectionMain id="slider-mapped" padding="sm" borderTop>
        <div class="flex flex-col gap-4 mb-6">
          <h2 class="h3">Slider — mapped from data</h2>
          <p class="mt-2 text-fg-muted">Same component, fed from an array (could be a content collection).</p>
        </div>

        <SliderBasicMap
          mobile={1}
          mobileLandscape={2}
          tablet={2}
          desktop={3}
          gap="md"
          ariaLabel="Mapped slides"
          titleClass="h4"
          titleTag="h4"
          items={[
            { eyebrow: "Guide", title: "Getting started",  description: "Spin up a project in under five minutes." },
            { eyebrow: "Reference", title: "Component API", description: "Props, slots, and data attributes for every component." },
            { eyebrow: "Tutorial", title: "Build a landing page", description: "Walk through composing sections from the starter kit." },
            { eyebrow: "Recipes", title: "Theming patterns", description: "Light/dark variants using Tailwind v4 tokens." },
          ]}
        />
      </SectionMain>

      <SectionMain id="combobox" padding="sm" borderTop>
        <div class="flex flex-col gap-4 mb-6">
          <h2 class="h3">Combobox — grouped</h2>
          <p class="mt-2 text-fg-muted">Searchable dropdown with grouped options, full keyboard nav, and form support.</p>
        </div>

        <div class="max-w-sm">
          <ComboboxGrouped
            name="framework"
            placeholder="Select a framework…"
            ariaLabel="Choose a framework"
            groups={[
              {
                heading: "Frameworks",
                items: [
                  { value: "astro", label: "Astro", description: "Content-focused, ships zero JS by default" },
                  { value: "nextjs", label: "Next.js", description: "React framework with SSR + static" },
                  { value: "nuxt", label: "Nuxt", description: "Vue framework with SSR + static" },
                  { value: "sveltekit", label: "SvelteKit", description: "Svelte's official meta-framework" },
                ],
              },
              {
                heading: "Styling",
                items: [
                  { value: "tailwind", label: "Tailwind CSS", description: "Utility-first CSS framework" },
                  { value: "vanilla-extract", label: "vanilla-extract", description: "Type-safe CSS-in-TS" },
                  { value: "css-modules", label: "CSS Modules", description: "Scoped class names" },
                ],
              },
              {
                heading: "Bundlers",
                items: [
                  { value: "vite", label: "Vite", description: "ESM-native dev server" },
                  { value: "esbuild", label: "esbuild", description: "Go-based, very fast" },
                  { value: "rollup", label: "Rollup", description: "Library-friendly bundler", disabled: true },
                ],
              },
            ]}
          />
        </div>
      </SectionMain>

      <SectionMain id="flow-steps" padding="none" contentPadding="none" borderTop>
        <FlowSteps
          title="How it works."
          description="Clicking a step slides the panel column — three panels stacked in one grid cell, each offset by index * 100% along the Y axis."
          steps={[
            { title: "Issue credentials from your portal", description: "Control the look and feel of your credential issuance directly in your portal. Our API enables a complete integration." },
            { title: "Craft a template to issue passes via API", description: "Display your brand (or your customer's) in wallet with ease. Then issue credentials via API that are delivered via text." },
            { title: "Users install your custom crafted credential", description: "With a SMS integration, your users receive a text message with a link to install the pass on their phone." },
          ]}
        >
          <Fragment slot="panel-0">
            <div class="w-full max-w-sm p-6 flex flex-col gap-5 rounded-2xl bg-panel shadow-popover">
              <div class="font-semibold text-sm">Add credential</div>
              <div class="flex flex-col gap-2">
                <div class="text-fg-muted text-xs">Credential type</div>
                <div class="rounded-lg border border-stroke bg-panel p-0.5 grid grid-cols-2">
                  <div class="py-1 px-3 flex justify-center rounded-md bg-panel text-xs font-medium">Card</div>
                  <div class="py-1 px-3 flex justify-center text-fg-subtle text-xs font-medium">Mobile</div>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-2">
                  <div class="text-fg-muted text-xs">Card number</div>
                  <div class="px-2 py-1 rounded-lg border border-stroke bg-panel text-fg-subtle text-xs">••••</div>
                </div>
                <div class="flex flex-col gap-2">
                  <div class="text-fg-muted text-xs">Facility code</div>
                  <div class="px-2 py-1 rounded-lg border border-intent bg-panel text-xs">1234</div>
                </div>
              </div>
              <div class="flex items-center justify-end gap-2">
                <div class="px-3 py-1.5 rounded-lg border border-stroke bg-panel text-xs font-medium">Cancel</div>
                <div class="px-3 py-1.5 rounded-lg bg-intent text-fg-on-intent text-xs font-semibold">Submit</div>
              </div>
            </div>
          </Fragment>

          <Fragment slot="panel-1">
            <div class="w-full max-w-sm p-5 rounded-2xl bg-fg shadow-popover font-mono text-xs leading-5 text-panel">
              <div><span class="text-[#DA8CFF]">curl</span> https://api.example.com/v1/credentials/ \</div>
              <div>--request POST \</div>
              <div>--header 'Content-Type: application/json' \</div>
              <div>--header 'x-acct-id: $ACCOUNT_ID' \</div>
              <div>--data '{'{'}</div>
              <div>&nbsp;&nbsp;"template_id": "0xd3adb33f",</div>
              <div>&nbsp;&nbsp;"full_name": "Ada Lovelace",</div>
              <div>&nbsp;&nbsp;"email": "ada@example.com",</div>
              <div>&nbsp;&nbsp;"expires_at": "2026-03-22T16:40:41Z"</div>
              <div>{'}'}</div>
            </div>
          </Fragment>

          <Fragment slot="panel-2">
            <div class="w-full max-w-sm p-6 rounded-2xl bg-canvas shadow-popover">
              <div class="text-xs text-fg-muted font-semibold text-center mb-4">Messages</div>
              <div class="flex flex-col divide-y divide-stroke">
                <div class="flex items-start gap-3 py-2.5">
                  <div class="size-7 rounded-full bg-intent/10 shrink-0 flex items-center justify-center">
                    <Icon name="lucide:badge-check" class="w-4 h-4 text-intent" aria-hidden="true" />
                  </div>
                  <div>
                    <div class="text-xs font-semibold">Playground</div>
                    <div class="text-xs text-fg-muted line-clamp-2">You can now access your employee badge using this link...</div>
                  </div>
                </div>
                <div class="flex items-start gap-3 py-2.5 opacity-60">
                  <div class="size-7 rounded-full bg-panel-muted shrink-0"></div>
                  <div>
                    <div class="text-xs font-semibold">Dad</div>
                    <div class="text-xs text-fg-muted line-clamp-2">Got you a bottle of red wine from the shop.</div>
                  </div>
                </div>
                <div class="flex items-start gap-3 py-2.5 opacity-60">
                  <div class="size-7 rounded-full bg-panel-muted shrink-0"></div>
                  <div>
                    <div class="text-xs font-semibold">FedEx</div>
                    <div class="text-xs text-fg-muted line-clamp-2">Your parcel is out for delivery today!</div>
                  </div>
                </div>
              </div>
            </div>
          </Fragment>
        </FlowSteps>
      </SectionMain>



    </main>
    <Footer />
  </Layout>