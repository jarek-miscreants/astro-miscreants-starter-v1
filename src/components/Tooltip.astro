---
// Tooltip — accessible popover-API tooltip. Hover + focus to open, Escape
// or blur/mouseleave to close, anchored to the trigger via a small JS
// positioner. The trigger is whatever element the consumer puts in the
// default slot — the script wires `aria-describedby` automatically.
//
// Markup:
//   <Tooltip text="Helpful tip">
//     <button>Hover me</button>
//   </Tooltip>
//
// Or with rich content via the `content` slot:
//   <Tooltip placement="bottom">
//     <button slot="trigger">Hover me</button>
//     <Fragment slot="content"><strong>Bold</strong> tip</Fragment>
//   </Tooltip>

interface Props {
  /** Plain-text tooltip body. Use `slot="content"` for rich content. */
  text?: string;
  /** Side of the trigger to anchor to. */
  placement?: "top" | "bottom" | "left" | "right";
  /** Show delay in ms (debounces accidental hovers). Default 200. */
  showDelay?: number;
  /** Hide delay in ms. Default 100. */
  hideDelay?: number;
  /** Stable ID for the tooltip element. Auto-generated otherwise. */
  id?: string;
  class?: string;
}

const {
  text,
  placement = "top",
  showDelay = 200,
  hideDelay = 100,
  id,
  class: className,
} = Astro.props;

const tooltipId = id ?? `tt-${Math.random().toString(36).slice(2, 10)}`;
const hasNamedTrigger = Astro.slots.has("trigger");
const hasContentSlot = Astro.slots.has("content");
---

<span
  data-tooltip="component"
  data-tooltip-placement={placement}
  data-tooltip-show-delay={showDelay}
  data-tooltip-hide-delay={hideDelay}
  data-tooltip-target={tooltipId}
  class:list={["tooltip", className]}
>
  {hasNamedTrigger ? <slot name="trigger" /> : <slot />}
  <span
    id={tooltipId}
    role="tooltip"
    popover="manual"
    data-tooltip="content"
    data-placement={placement}
  >
    {hasContentSlot ? <slot name="content" /> : text}
    <span data-tooltip="arrow" aria-hidden="true"></span>
  </span>
</span>

<style is:global>
  [data-tooltip="component"] {
    display: contents;
  }

  [data-tooltip="content"][popover] {
    position: fixed;
    margin: 0;
    padding: 0.375rem 0.625rem;
    inset: auto;
    max-width: 20rem;
    border: 1px solid var(--color-stroke);
    background: var(--color-fg);
    color: var(--color-canvas);
    font-size: 0.8125rem;
    line-height: 1.4;
    box-shadow: var(--shadow-popover, 0 4px 12px -4px rgb(0 0 0 / 0.2));
    overflow: visible; /* let arrow poke outside */
    pointer-events: none; /* tooltips don't intercept hover */

    /* Animation in/out (display: discrete + opacity transitions). */
    opacity: 0;
    transform: translateY(2px);
    transition:
      opacity 100ms ease,
      transform 100ms ease,
      overlay 100ms allow-discrete,
      display 100ms allow-discrete;
  }

  [data-tooltip="content"][popover]:popover-open {
    opacity: 1;
    transform: translateY(0);
  }

  @starting-style {
    [data-tooltip="content"][popover]:popover-open {
      opacity: 0;
      transform: translateY(2px);
    }
  }

  /* Arrow — small rotated square anchored to whichever edge faces the trigger.
     The two borders facing outward stay; the two facing into the tooltip body
     are stripped so the arrow looks continuous with the tooltip border. */
  [data-tooltip="arrow"] {
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--color-fg);
    border: 1px solid var(--color-stroke);
    pointer-events: none;
  }

  [data-tooltip="content"][data-placement="top"] [data-tooltip="arrow"] {
    bottom: -5px;
    left: var(--tt-arrow-x, 50%);
    transform: translateX(-50%) rotate(45deg);
    border-top: 0;
    border-left: 0;
  }
  [data-tooltip="content"][data-placement="bottom"] [data-tooltip="arrow"] {
    top: -5px;
    left: var(--tt-arrow-x, 50%);
    transform: translateX(-50%) rotate(45deg);
    border-bottom: 0;
    border-right: 0;
  }
  [data-tooltip="content"][data-placement="left"] [data-tooltip="arrow"] {
    right: -5px;
    top: var(--tt-arrow-y, 50%);
    transform: translateY(-50%) rotate(45deg);
    border-bottom: 0;
    border-left: 0;
  }
  [data-tooltip="content"][data-placement="right"] [data-tooltip="arrow"] {
    left: -5px;
    top: var(--tt-arrow-y, 50%);
    transform: translateY(-50%) rotate(45deg);
    border-top: 0;
    border-right: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-tooltip="content"][popover] {
      transition-duration: 0ms !important;
    }
  }
</style>

<script>
  type Placement = "top" | "bottom" | "left" | "right";

  const initOne = (root: HTMLElement) => {
    if (root.dataset.scriptInitialized) return;
    root.dataset.scriptInitialized = "true";

    const targetId = root.getAttribute("data-tooltip-target");
    if (!targetId) return;
    const tooltip = document.getElementById(targetId);
    if (!tooltip) return;

    // Locate the trigger: first focusable descendant that isn't the tooltip.
    const trigger =
      root.querySelector<HTMLElement>(
        "button, a, [tabindex], input, summary, select, textarea"
      ) ?? root.firstElementChild as HTMLElement | null;
    if (!trigger || trigger === tooltip || trigger.contains(tooltip)) return;

    // Wire ARIA.
    const existing = trigger.getAttribute("aria-describedby");
    trigger.setAttribute(
      "aria-describedby",
      existing ? `${existing} ${targetId}` : targetId
    );

    const placement = (root.getAttribute("data-tooltip-placement") || "top") as Placement;
    const showDelay = Number(root.getAttribute("data-tooltip-show-delay")) || 200;
    const hideDelay = Number(root.getAttribute("data-tooltip-hide-delay")) || 100;

    let showTimer: ReturnType<typeof setTimeout> | null = null;
    let hideTimer: ReturnType<typeof setTimeout> | null = null;
    let isOpen = false;

    const reposition = () => {
      const trg = trigger.getBoundingClientRect();
      const tip = tooltip.getBoundingClientRect();
      const margin = 8; // leaves room for the arrow + a hair of breathing room
      let top = 0;
      let left = 0;

      switch (placement) {
        case "top":
          top = trg.top - tip.height - margin;
          left = trg.left + (trg.width - tip.width) / 2;
          break;
        case "bottom":
          top = trg.bottom + margin;
          left = trg.left + (trg.width - tip.width) / 2;
          break;
        case "left":
          top = trg.top + (trg.height - tip.height) / 2;
          left = trg.left - tip.width - margin;
          break;
        case "right":
          top = trg.top + (trg.height - tip.height) / 2;
          left = trg.right + margin;
          break;
      }

      // Clamp into viewport.
      top = Math.max(8, Math.min(top, window.innerHeight - tip.height - 8));
      left = Math.max(8, Math.min(left, window.innerWidth - tip.width - 8));

      tooltip.style.top = `${top}px`;
      tooltip.style.left = `${left}px`;

      // Track the arrow to the trigger's center even when the tooltip got
      // clamped against an edge. Keep it inset from the corners so it doesn't
      // overrun the borders.
      const arrowInset = 10;
      if (placement === "top" || placement === "bottom") {
        const triggerCenterX = trg.left + trg.width / 2;
        const rawX = triggerCenterX - left;
        const x = Math.max(arrowInset, Math.min(rawX, tip.width - arrowInset));
        tooltip.style.setProperty("--tt-arrow-x", `${x}px`);
      } else {
        const triggerCenterY = trg.top + trg.height / 2;
        const rawY = triggerCenterY - top;
        const y = Math.max(arrowInset, Math.min(rawY, tip.height - arrowInset));
        tooltip.style.setProperty("--tt-arrow-y", `${y}px`);
      }
    };

    const open = () => {
      if (isOpen) return;
      tooltip.showPopover();
      isOpen = true;
      // Defer reposition until layout is computed.
      requestAnimationFrame(reposition);
    };

    const close = () => {
      if (!isOpen) return;
      tooltip.hidePopover();
      isOpen = false;
    };

    const scheduleOpen = () => {
      if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      if (showTimer) return;
      showTimer = setTimeout(() => {
        showTimer = null;
        open();
      }, showDelay);
    };

    const scheduleClose = () => {
      if (showTimer) { clearTimeout(showTimer); showTimer = null; }
      if (hideTimer) return;
      hideTimer = setTimeout(() => {
        hideTimer = null;
        close();
      }, hideDelay);
    };

    // Hover (pointer)
    trigger.addEventListener("pointerenter", scheduleOpen);
    trigger.addEventListener("pointerleave", scheduleClose);
    // Keyboard / a11y
    trigger.addEventListener("focus", open);
    trigger.addEventListener("blur", close);
    // Escape closes globally while open
    trigger.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        e.stopPropagation();
        close();
      }
    });
    // Disappear on scroll/resize so we don't leave tooltips floating in the wrong place
    window.addEventListener("scroll", close, { passive: true, capture: true });
    window.addEventListener("resize", close);
  };

  const initAll = () =>
    document.querySelectorAll<HTMLElement>('[data-tooltip="component"]').forEach(initOne);

  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>
