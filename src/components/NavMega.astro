---
import Logo from "./Logo.astro";
import Button from "./Button.astro";



interface NavLink {
  label: string;
  href: string;
  description?: string;
}

interface NavPanel {
  name: string;
  columns: { heading?: string; links: NavLink[] }[];
}

const panels: NavPanel[] = [
  {
    name: "Products",
    columns: [
      {
        heading: "Platform",
        links: [
          { label: "Overview", href: "/overview", description: "See everything in one place" },
          { label: "Analytics", href: "/analytics", description: "Insights and reporting" },
          { label: "Integrations", href: "/integrations", description: "Connect your stack" },
          { label: "Automation", href: "/automation", description: "Workflows that scale" },
        ],
      },
      {
        heading: "Developer",
        links: [
          { label: "API", href: "/api", description: "Build with our API" },
          { label: "SDKs", href: "/sdks", description: "Libraries for every language" },
          { label: "Docs", href: "/docs", description: "Guides and references" },
        ],
      },
    ],
  },
  {
    name: "Solutions",
    columns: [
      {
        heading: "By Role",
        links: [
          { label: "Enterprise", href: "/enterprise", description: "For large teams" },
          { label: "Startups", href: "/startups", description: "Get off the ground fast" },
          { label: "Agencies", href: "/agencies", description: "Manage multiple clients" },
        ],
      },
      {
        heading: "By Industry",
        links: [
          { label: "SaaS", href: "/saas", description: "Software companies" },
          { label: "E-commerce", href: "/ecommerce", description: "Online retail" },
          { label: "Finance", href: "/finance", description: "Banking and fintech" },
        ],
      },
    ],
  },
  {
    name: "Company",
    columns: [
      {
        links: [
          { label: "About", href: "/about", description: "Our story and mission" },
          { label: "Careers", href: "/careers", description: "Join the team" },
          { label: "Blog", href: "/blog", description: "News and updates" },
          { label: "Contact", href: "/contact", description: "Get in touch" },
        ],
      },
    ],
  },
];

const topLinks = [
  { label: "Pricing", href: "/pricing" },
];
---

<nav class="sticky top-0 z-50">
  <div data-menu-wrap data-menu-open="false" class="relative" style="--nav-height: 4rem;">

    <!-- ─── Top Bar ─── -->
    <div class="relative z-40 border-b border-gray-200 bg-white">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">

        <!-- Logo -->
        <a data-menu-logo href="/" class="flex shrink-0 items-center gap-2 text-lg font-bold max-w-40 h-full">
          <Logo />
         
        </a>

        <!-- Mobile Back Button -->
        <button
          data-mobile-back
          class="absolute left-6 flex items-center gap-1 text-sm font-medium text-gray-600 opacity-0 lg:hidden"
          aria-label="Back to menu"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Back
        </button>

        <!-- Desktop Nav -->
        <div class="hidden items-center gap-1 lg:flex">
          {panels.map((panel) => (
            <button
              data-dropdown-toggle={panel.name}
              class="flex items-center gap-1 rounded-sm pl-3 pr-2 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900"
              aria-expanded="false"
            >
              {panel.name}
              <svg class="size-4 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
          ))}
          {topLinks.map((link) => (
            <a href={link.href} class="rounded-sm pl-3 pr-2 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900">
              {link.label}
            </a>
          ))}
        </div>

        <!-- Right side: CTA + Burger -->
        <div class="flex items-center gap-3">
          <a href="/signup" class="hidden rounded-sm bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-indigo-700 sm:inline-flex">
            Get Started
          </a>

          <!-- Burger -->
          <button
            data-burger-toggle
            class="relative flex size-10 flex-col items-center justify-center gap-[0.3125em] lg:hidden"
            aria-expanded="false"
            aria-label="Toggle menu"
          >
            <div data-burger-line="top" class="h-0.5 w-5 origin-center bg-gray-900"></div>
            <div data-burger-line="mid" class="h-0.5 w-5 origin-center bg-gray-900"></div>
            <div data-burger-line="bot" class="h-0.5 w-5 origin-center bg-gray-900"></div>
          </button>
        </div>
      </div>
    </div>

    <!-- ─── Mobile Nav List ─── -->
    <div
      data-nav-list
      class="fixed inset-x-0 bottom-0 z-30 overflow-y-auto bg-white px-6 py-4 lg:hidden"
    >
      {panels.map((panel) => (
        <div data-nav-list-item class="border-b border-gray-100">
          <button
            data-dropdown-toggle={panel.name}
            class="flex w-full items-center justify-between py-4 text-base font-medium text-gray-900"
          >
            {panel.name}
            <svg class="size-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      ))}
      {topLinks.map((link) => (
        <div data-nav-list-item class="border-b border-gray-100">
          <a href={link.href} class="flex py-4 text-base font-medium text-gray-900">
            {link.label}
          </a>
        </div>
      ))}
      <div data-nav-list-item class="pt-4">
        <a href="/signup" class="flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-3 text-sm font-medium text-white">
          Get Started
        </a>
      </div>
    </div>

    <!-- ─── Dropdown Wrapper (shared by desktop + mobile) ─── -->
    <div data-dropdown-wrapper class="fixed inset-x-0 z-30 max-lg:bottom-0 max-lg:overflow-y-auto max-lg:pointer-events-none">
      <div data-dropdown-container class="relative mx-auto max-w-7xl overflow-hidden max-lg:!overflow-visible max-lg:!h-auto max-lg:px-6 max-lg:py-4" style="height: 0;">

        {panels.map((panel) => (
          <div
            data-nav-content={panel.name}
            class="absolute inset-x-0 top-0 max-lg:static max-lg:overflow-y-auto max-lg:bg-white max-lg:px-6 max-lg:py-4"
          >
            <div class="rounded-b-2xl border-x border-b border-gray-200 bg-white shadow-xl max-lg:border-0 max-lg:shadow-none">
              <div class={`grid gap-8 p-8 max-lg:grid-cols-1 max-lg:gap-6 max-lg:p-0 ${panel.columns.length > 1 ? "lg:grid-cols-2" : "grid-cols-1"}`}>
                {panel.columns.map((col) => (
                  <div>
                    {col.heading && (
                      <div data-menu-fade class="mb-4 text-xs font-semibold uppercase tracking-wider text-gray-400">
                        {col.heading}
                      </div>
                    )}
                    <div class="space-y-1">
                      {col.links.map((link) => (
                        <a
                          data-menu-fade
                          href={link.href}
                          class="group -mx-3 flex flex-col rounded-lg px-3 py-2.5 transition-colors hover:bg-gray-50"
                        >
                          <span class="text-sm font-medium text-gray-900 group-hover:text-indigo-600">
                            {link.label}
                          </span>
                          {link.description && (
                            <span class="text-sm text-gray-500">
                              {link.description}
                            </span>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}

        <div data-dropdown-bg></div>
      </div>
    </div>

    <!-- ─── Backdrop ─── -->
    <div
      data-menu-backdrop
      class="fixed inset-x-0 bottom-0 z-20 bg-black/20 backdrop-blur-sm"
    ></div>

  </div>
</nav>

<style>
  /* ─── Dropdown container: height morphs smoothly between panels ─── */
  [data-dropdown-container] {
    transition: height 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ─── Backdrop fade ─── */
  [data-menu-backdrop] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }
  [data-menu-wrap][data-menu-open="true"] [data-menu-backdrop] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }

  /* ─── Panel visibility ─── */
  [data-nav-content] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0s linear 0.25s;
  }
  [data-nav-content][data-state="active"] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.25s ease, visibility 0s linear 0s;
  }

  /* ─── Staggered content fade-in ─── */
  [data-menu-fade] {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  [data-nav-content][data-state="active"] [data-menu-fade] {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--stagger-i, 0) * 40ms + 80ms);
  }

  /* ─── Burger icon → X animation ─── */
  [data-burger-line] {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.15s ease;
  }
  @media (max-width: 991px) {
    [data-menu-wrap][data-menu-open="true"] [data-burger-line="top"] {
      transform: translateY(0.3125em) rotate(45deg);
    }
    [data-menu-wrap][data-menu-open="true"] [data-burger-line="mid"] {
      opacity: 0;
    }
    [data-menu-wrap][data-menu-open="true"] [data-burger-line="bot"] {
      transform: translateY(-0.3125em) rotate(-45deg);
    }
  }

  /* ─── Mobile nav list fade ─── */
  [data-nav-list] {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }
  @media (max-width: 991px) {
    [data-menu-wrap][data-menu-open="true"] [data-nav-list] {
      opacity: 1;
      visibility: visible;
      transition: opacity 0.3s ease, visibility 0s linear 0s;
    }

    /* Staggered nav list items */
    [data-nav-list-item] {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    [data-menu-wrap][data-menu-open="true"] [data-nav-list-item] {
      opacity: 1;
      transform: translateY(0);
      transition-delay: calc(var(--stagger-i, 0) * 40ms + 150ms);
    }

    /* Mobile: panels overlay the nav list instead of stacking in flow */
    [data-dropdown-wrapper] {
      pointer-events: none;
    }
    [data-menu-wrap][data-mobile-panel-open="true"] [data-dropdown-wrapper] {
      pointer-events: auto;
    }
    [data-dropdown-container] {
      height: auto !important;
      overflow: visible !important;
      position: static;
      max-width: none;
      padding: 0;
    }
    [data-nav-content] {
      position: absolute !important;
      inset: 0;
      top: 0;
      background: white;
      overflow-y: auto;
      padding: 1rem 1.5rem 2rem;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateX(8%);
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0s linear 0.3s;
    }
    [data-nav-content][data-state="active"] {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(0);
      transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s, visibility 0s linear 0s;
    }

    /* Mobile back button */
    [data-mobile-back] {
      transition: opacity 0.25s ease;
    }
    [data-menu-wrap][data-mobile-panel-open="true"] [data-mobile-back] {
      opacity: 1 !important;
    }
    [data-menu-wrap][data-mobile-panel-open="true"] [data-menu-logo] {
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    [data-menu-logo] {
      transition: opacity 0.25s ease;
    }
  }

  /* ─── Announcement banner height transition ─── */
  [data-announcement="banner"] {
    overflow: hidden;
    transition: height 0.3s ease;
    will-change: height;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    [data-dropdown-container],
    [data-menu-backdrop],
    [data-nav-content],
    [data-menu-fade],
    [data-burger-line],
    [data-nav-list],
    [data-nav-list-item],
    [data-mobile-back],
    [data-menu-logo],
    [data-announcement="banner"] {
      transition: none !important;
    }
  }
</style>

<!-- ─── Mega Nav Script (CSS-only animations) ─── -->
<script is:inline>
(function(){
  const HOVER_ENTER = 120;
  const HOVER_LEAVE = 150;
  const MOBILE_BREAKPOINT = 991;

  // ─── DOM refs ───
  const menuWrap = document.querySelector("[data-menu-wrap]");
  const navList = document.querySelector("[data-nav-list]");
  const dropWrapper = document.querySelector("[data-dropdown-wrapper]");
  const dropContainer = document.querySelector("[data-dropdown-container]");
  const backdrop = document.querySelector("[data-menu-backdrop]");
  const toggles = [...document.querySelectorAll("[data-dropdown-toggle]")];
  const panels = [...document.querySelectorAll("[data-nav-content]")];
  const burger = document.querySelector("[data-burger-toggle]");
  const backBtn = document.querySelector("[data-mobile-back]");
  const navBar = menuWrap.querySelector(".relative.z-40");

  // ─── Set stagger index on fade elements and nav items (drives CSS delay) ───
  panels.forEach((p) => {
    p.querySelectorAll("[data-menu-fade]").forEach((el, i) => {
      el.style.setProperty("--stagger-i", i);
    });
  });
  navList.querySelectorAll("[data-nav-list-item]").forEach((el, i) => {
    el.style.setProperty("--stagger-i", i);
  });

  // ─── Dynamic top offset (accounts for announcement banner height) ───
  function syncTopOffset() {
    const top = navBar.getBoundingClientRect().bottom + "px";
    navList.style.top = top;
    dropWrapper.style.top = top;
    backdrop.style.top = top;
  }
  syncTopOffset();
  window.addEventListener("scroll", syncTopOffset, { passive: true });
  window.addEventListener("resize", syncTopOffset);
  const banner = document.querySelector("[data-announcement='banner']");
  if (banner) new ResizeObserver(syncTopOffset).observe(banner);

  // ─── State ───
  const state = {
    activePanel: null,
    isMobile: window.innerWidth <= MOBILE_BREAKPOINT,
    mobileOpen: false,
    mobilePanelActive: null,
    hoverTimer: null,
    leaveTimer: null,
  };

  // ─── Helpers ───
  const getPanel = (name) => document.querySelector(`[data-nav-content="${name}"]`);
  const getToggle = (name) => document.querySelector(`[data-dropdown-toggle="${name}"]`);
  const resetToggles = () => toggles.forEach((t) => t.setAttribute("aria-expanded", "false"));

  // Measure a panel's natural height while keeping it invisible.
  // We toggle [data-state="measuring"] briefly so CSS doesn't apply the fade.
  function measurePanel(name) {
    const el = getPanel(name);
    if (!el) return 0;
    const prevVis = el.style.visibility;
    const prevOpacity = el.style.opacity;
    const prevPointer = el.style.pointerEvents;
    el.style.visibility = "hidden";
    el.style.opacity = "0";
    el.style.pointerEvents = "none";
    // Temporarily disable transitions for measurement
    el.setAttribute("data-state", "active");
    const h = el.getBoundingClientRect().height;
    el.removeAttribute("data-state");
    el.style.visibility = prevVis;
    el.style.opacity = prevOpacity;
    el.style.pointerEvents = prevPointer;
    return h;
  }

  // ─── Desktop dropdown ───
  function openDropdown(panelName) {
    if (state.activePanel === panelName) return;
    const height = measurePanel(panelName);
    if (!height) return;

    // Deactivate any other active panel so CSS can fade it out
    panels.forEach((p) => {
      if (p.getAttribute("data-nav-content") !== panelName) {
        p.removeAttribute("data-state");
      }
    });

    const el = getPanel(panelName);
    el.setAttribute("data-state", "active");
    dropContainer.style.height = height + "px";
    menuWrap.setAttribute("data-menu-open", "true");

    resetToggles();
    const t = getToggle(panelName);
    if (t) t.setAttribute("aria-expanded", "true");

    state.activePanel = panelName;
  }

  function closeDropdown() {
    if (!state.activePanel) return;
    panels.forEach((p) => p.removeAttribute("data-state"));
    dropContainer.style.height = "0px";
    menuWrap.setAttribute("data-menu-open", "false");
    resetToggles();
    state.activePanel = null;
  }

  // ─── Hover intent ───
  function clearTimers() {
    clearTimeout(state.hoverTimer);
    clearTimeout(state.leaveTimer);
    state.hoverTimer = state.leaveTimer = null;
  }

  function handleToggleEnter(e) {
    if (state.isMobile) return;
    const name = e.currentTarget.getAttribute("data-dropdown-toggle");
    if (!name) return;
    clearTimeout(state.leaveTimer);
    state.leaveTimer = null;
    clearTimeout(state.hoverTimer);
    // When a panel is already open, switch instantly; otherwise wait for intent
    state.hoverTimer = setTimeout(
      () => openDropdown(name),
      state.activePanel ? 0 : HOVER_ENTER
    );
  }

  function handleToggleLeave() {
    if (state.isMobile) return;
    clearTimeout(state.hoverTimer);
    state.hoverTimer = null;
    state.leaveTimer = setTimeout(closeDropdown, HOVER_LEAVE);
  }

  function handleWrapperEnter() {
    if (state.isMobile) return;
    clearTimeout(state.leaveTimer);
    state.leaveTimer = null;
  }

  function handleWrapperLeave() {
    if (state.isMobile) return;
    state.leaveTimer = setTimeout(closeDropdown, HOVER_LEAVE);
  }

  // ─── Click / keyboard on toggle ───
  function handleToggleClick(e) {
    const name = e.currentTarget.getAttribute("data-dropdown-toggle");
    if (state.isMobile && state.mobileOpen) {
      e.preventDefault();
      openMobilePanel(name);
      return;
    }
    if (!state.isMobile) {
      if (state.activePanel === name) closeDropdown();
      else openDropdown(name);
    }
  }

  function focusFirstLink(panelName) {
    setTimeout(() => {
      const link = getPanel(panelName)?.querySelector("a");
      link?.focus();
    }, 80);
  }

  function handleKeydownOnToggle(e) {
    if (state.isMobile) return;
    const name = e.currentTarget.getAttribute("data-dropdown-toggle");
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      if (state.activePanel === name) closeDropdown();
      else {
        openDropdown(name);
        focusFirstLink(name);
      }
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      if (state.activePanel !== name) openDropdown(name);
      focusFirstLink(name);
    }
  }

  function handleKeydownInPanel(e) {
    if (state.isMobile || !state.activePanel) return;
    const el = getPanel(state.activePanel);
    if (!el) return;
    const links = [...el.querySelectorAll("a")];
    const idx = links.indexOf(document.activeElement);
    if (e.key === "ArrowDown") {
      e.preventDefault();
      links[(idx + 1) % links.length].focus();
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      if (idx <= 0) getToggle(state.activePanel)?.focus();
      else links[idx - 1].focus();
    }
  }

  // ─── Close behaviors ───
  function handleEscape(e) {
    if (e.key !== "Escape") return;
    if (state.isMobile) {
      if (state.mobilePanelActive) closeMobilePanel();
      else if (state.mobileOpen) closeMobileMenu();
      return;
    }
    if (state.activePanel) {
      const t = getToggle(state.activePanel);
      closeDropdown();
      t?.focus();
    }
  }

  function handleDocClick(e) {
    if (state.isMobile || !state.activePanel) return;
    if (!e.target.closest("[data-menu-wrap]")) closeDropdown();
  }

  // ─── Mobile menu ───
  function openMobileMenu() {
    state.mobileOpen = true;
    menuWrap.setAttribute("data-menu-open", "true");
    burger.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMobileMenu() {
    state.mobileOpen = false;
    state.mobilePanelActive = null;
    menuWrap.setAttribute("data-menu-open", "false");
    menuWrap.setAttribute("data-mobile-panel-open", "false");
    burger.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    panels.forEach((p) => p.removeAttribute("data-state"));
    dropContainer.style.height = "";
  }

  function openMobilePanel(panelName) {
    const el = getPanel(panelName);
    if (!el) return;
    panels.forEach((p) => p.removeAttribute("data-state"));
    el.setAttribute("data-state", "active");
    state.mobilePanelActive = panelName;
    menuWrap.setAttribute("data-mobile-panel-open", "true");
  }

  function closeMobilePanel() {
    if (!state.mobilePanelActive) return;
    const el = getPanel(state.mobilePanelActive);
    el?.removeAttribute("data-state");
    state.mobilePanelActive = null;
    menuWrap.setAttribute("data-mobile-panel-open", "false");
  }

  // ─── Resize handler (reset state when crossing breakpoint) ───
  let resizeTimer = null;
  let lastWidth = window.innerWidth;
  function handleResize() {
    const w = window.innerWidth;
    if (w === lastWidth) return;
    lastWidth = w;
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const wasMobile = state.isMobile;
      state.isMobile = window.innerWidth <= MOBILE_BREAKPOINT;
      if (wasMobile !== state.isMobile) {
        closeDropdown();
        closeMobileMenu();
        clearTimers();
      }
    }, 150);
  }

  // ─── Bind events ───
  toggles.forEach((btn) => {
    btn.addEventListener("mouseenter", handleToggleEnter);
    btn.addEventListener("mouseleave", handleToggleLeave);
    btn.addEventListener("keydown", handleKeydownOnToggle);
    btn.addEventListener("click", handleToggleClick);
  });
  dropWrapper.addEventListener("mouseenter", handleWrapperEnter);
  dropWrapper.addEventListener("mouseleave", handleWrapperLeave);
  panels.forEach((p) => p.addEventListener("keydown", handleKeydownInPanel));
  backdrop.addEventListener("click", closeDropdown);
  document.addEventListener("keydown", handleEscape);
  document.addEventListener("click", handleDocClick);
  burger.addEventListener("click", () =>
    state.mobileOpen ? closeMobileMenu() : openMobileMenu()
  );
  backBtn.addEventListener("click", closeMobilePanel);
  window.addEventListener("resize", handleResize);

  // Init
  menuWrap.setAttribute("data-menu-open", "false");
  menuWrap.setAttribute("data-mobile-panel-open", "false");
})();
</script>

<!-- Announcement Banner Script -->
<script is:inline>
(function(){
  const banner = document.querySelector("[data-announcement='banner']");
  if (!banner) return;
  const closeBtn = banner.querySelector("[data-announcement='close']");
  const STORAGE_KEY = "announcement-dismissed";

  if (sessionStorage.getItem(STORAGE_KEY)) { banner.style.display = "none"; return; }

  function measureHeight() { banner.style.height = "auto"; return banner.offsetHeight; }
  let naturalHeight = measureHeight();
  banner.style.height = naturalHeight + "px";
  let isHidden = false, isDismissed = false, lastScrollY = window.scrollY;

  window.addEventListener("resize", () => {
    if (isDismissed) return;
    naturalHeight = measureHeight();
    if (!isHidden) banner.style.height = naturalHeight + "px";
  });

  function show() {
    if (isDismissed || !isHidden) return;
    isHidden = false;
    banner.style.height = naturalHeight + "px";
  }
  function hide() {
    if (isDismissed || isHidden) return;
    isHidden = true;
    banner.style.height = "0px";
  }
  function dismiss() {
    isDismissed = true;
    sessionStorage.setItem(STORAGE_KEY, "1");
    banner.style.height = "0px";
    banner.addEventListener("transitionend", () => { banner.style.display = "none"; }, { once: true });
  }

  window.addEventListener("scroll", () => {
    if (isDismissed) return;
    const y = window.scrollY, delta = y - lastScrollY;
    if (delta > 5) hide(); else if (delta < -5) show();
    lastScrollY = y;
  }, { passive: true });

  if (closeBtn) {
    closeBtn.addEventListener("click", dismiss);
    closeBtn.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); dismiss(); } });
  }
})();
</script>
