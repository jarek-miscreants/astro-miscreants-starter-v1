---
// CodeBlock — wraps astro:components <Code /> with a title bar, language
// badge, copy button, optional line numbers, and optional line highlighting
// driven by an array of 1-based line numbers.
//
// Usage:
//   <CodeBlock
//     code={`const x = 1;\nconsole.log(x);`}
//     lang="ts"
//     title="example.ts"
//     showLineNumbers
//     highlight={[2]}
//   />
//
// Highlighting is implemented as a shiki transformer that adds a
// `data-line-highlight` attribute to matching `<span class="line">` rows.
// Line numbers are CSS-counter based.

import { Code } from "astro:components";
import CopyButton from "./CopyButton.astro";

interface Props {
  /** Source code. Required. */
  code: string;
  /** Shiki language id. Default "plaintext". */
  lang?: string;
  /** Filename or label shown in the title bar. */
  title?: string;
  /** 1-based line numbers to highlight. */
  highlight?: number[];
  /** Show 1-based line numbers in a gutter. */
  showLineNumbers?: boolean;
  /** Hide the language badge. */
  hideLang?: boolean;
  /** Hide the copy button. */
  hideCopy?: boolean;
  class?: string;
}

const {
  code,
  lang = "plaintext",
  title,
  highlight = [],
  showLineNumbers = false,
  hideLang = false,
  hideCopy = false,
  class: className,
} = Astro.props;

// Shiki transformer: tag highlighted lines with a data attribute. Line
// counter starts at 1 because that's how editors and stack traces refer
// to lines.
const highlightSet = new Set(highlight);
const transformers = highlightSet.size > 0
  ? [{
      name: "codeblock-highlight",
      line(node: any, line: number) {
        if (highlightSet.has(line)) {
          node.properties = node.properties || {};
          node.properties["data-line-highlight"] = "true";
        }
      },
    }]
  : undefined;
---

<figure
  data-codeblock
  data-codeblock-line-numbers={showLineNumbers ? "true" : undefined}
  data-theme="dark"
  class:list={["code-block", className]}
>
  {(title || !hideLang || !hideCopy) && (
    <figcaption data-codeblock-toolbar>
      <span data-codeblock-title>{title}</span>
      <span data-codeblock-spacer></span>
      {!hideLang && lang && lang !== "plaintext" && (
        <span data-codeblock-lang>{lang}</span>
      )}
      {!hideCopy && (
        <CopyButton value={code} label="Copy code" class="code-block__copy" />
      )}
    </figcaption>
  )}
  <div data-codeblock-content>
    <Code code={code} lang={lang} transformers={transformers} />
  </div>
</figure>

<style is:global>
  [data-codeblock] {
    margin: 1rem 0;
    border: 1px solid var(--color-stroke);
    background: var(--color-panel);
    color: var(--color-fg);
    overflow: hidden;
  }

  /* ----- Toolbar ----- */
  [data-codeblock-toolbar] {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    border-bottom: 1px solid var(--color-stroke);
    background: var(--color-panel-muted);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
  }
  [data-codeblock-title] {
    font-weight: 500;
  }
  [data-codeblock-spacer] {
    flex: 1;
  }
  [data-codeblock-lang] {
    text-transform: uppercase;
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.375rem;
    background: var(--color-panel);
    border: 1px solid var(--color-stroke);
  }
  .code-block__copy {
    padding: 0.25rem 0.5rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-fg-muted);
  }
  .code-block__copy:hover {
    background: var(--color-panel);
    border-color: var(--color-stroke);
    color: var(--color-fg);
  }

  /* ----- Code area ----- */
  [data-codeblock-content] pre {
    margin: 0;
    padding: 0.875rem 1rem;
    overflow-x: auto;
    background: transparent !important;  /* shiki sets a bg; we want our panel color */
    font-size: 0.8125rem;
    line-height: 1.55;
  }

  /* ----- Line highlight (set by transformer) ----- */
  [data-codeblock-content] .line[data-line-highlight] {
    display: inline-block;
    width: 100%;
    background: rgb(255 200 0 / 0.1);
    box-shadow: inset 2px 0 0 var(--color-intent);
  }

  /* ----- Line numbers (CSS counters) ----- */
  [data-codeblock][data-codeblock-line-numbers] [data-codeblock-content] pre code {
    counter-reset: codeblock-line;
  }
  [data-codeblock][data-codeblock-line-numbers] [data-codeblock-content] .line {
    counter-increment: codeblock-line;
  }
  [data-codeblock][data-codeblock-line-numbers] [data-codeblock-content] .line::before {
    content: counter(codeblock-line);
    display: inline-block;
    width: 2em;
    margin-right: 1em;
    text-align: right;
    color: var(--color-fg-subtle);
    user-select: none;
  }
  /* The trailing empty line shiki appends shouldn't show a number. */
  [data-codeblock][data-codeblock-line-numbers] [data-codeblock-content] .line:last-child:empty::before {
    content: "";
  }
</style>
