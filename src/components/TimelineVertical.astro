---
// TimelineVertical — vertical timeline / changelog / company-history list.
// Data-driven by default (pass `items`); slot-based escape hatch when
// items contain rich JSX (links, badges, code snippets).
//
// Usage:
//   <TimelineVertical items={[
//     { date: "Jan 2024", title: "Founded", description: "Started the company." },
//     { date: "Mar 2024", title: "Series A", description: "Raised seed round.", status: "current" },
//     { date: "Q3 2024", title: "Product launch", status: "future" },
//   ]} />
//
// Or with rich content via the default slot:
//   <TimelineVertical>
//     <li data-timeline-item>
//       <time data-timeline-date>Jan 2024</time>
//       <h3 data-timeline-title>Founded</h3>
//       <p>Started the company. <a href="...">Read more</a>.</p>
//     </li>
//   </TimelineVertical>

interface Item {
  /** Display text for the date (e.g. "Jan 2024", "Q3", "v1.4.0"). */
  date?: string;
  /** ISO date for the <time datetime="..."> attribute. */
  dateAttribute?: string;
  /** Item heading. Required when using `items`. */
  title: string;
  /** Body copy under the title. Plain text (use slot for rich content). */
  description?: string;
  /** Visual state of the marker. */
  status?: "default" | "complete" | "current" | "future";
}

interface Props {
  /** Item data. Omit to drive via the default slot. */
  items?: Item[];
  /** Show markers as outline rings instead of filled dots. */
  outlineMarkers?: boolean;
  /** Accessible label for the surrounding region. */
  ariaLabel?: string;
  class?: string;
}

const {
  items,
  outlineMarkers = false,
  ariaLabel,
  class: className,
} = Astro.props;
---

<div
  data-timeline="component"
  data-timeline-outline={outlineMarkers ? "true" : undefined}
  aria-label={ariaLabel}
  class:list={["timeline", className]}
>
  <ol data-timeline-list>
    {items ? (
      items.map((item) => (
        <li
          data-timeline-item
          data-timeline-status={item.status ?? "default"}
        >
          <span data-timeline-marker aria-hidden="true"></span>
          {item.date && (
            <time
              data-timeline-date
              datetime={item.dateAttribute}
            >{item.date}</time>
          )}
          <h3 data-timeline-title>{item.title}</h3>
          {item.description && (
            <p data-timeline-description>{item.description}</p>
          )}
        </li>
      ))
    ) : (
      <slot />
    )}
  </ol>
</div>

<style is:global>
  [data-timeline="component"] [data-timeline-list] {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* The connecting line. Lives on each item so it doesn't extend past the
     last marker (cleaner than a single line behind everything). */
  [data-timeline-item] {
    position: relative;
    padding-left: 2.25rem;
    padding-bottom: 1.75rem;
    margin: 0;
  }
  [data-timeline-item]::before {
    content: "";
    position: absolute;
    left: 0.4375rem;
    top: 0.875rem;
    bottom: 0;
    width: 1px;
    background: var(--color-stroke);
  }
  [data-timeline-item]:last-child::before {
    /* Last item — line stops at the marker (no trailing stub). */
    bottom: calc(100% - 0.875rem);
    display: none;
  }

  /* Marker dot. */
  [data-timeline-marker] {
    position: absolute;
    left: 0;
    top: 0.375rem;
    width: 1rem;
    height: 1rem;
    background: var(--color-fg);
    border: 2px solid var(--color-canvas);
    box-shadow: 0 0 0 1px var(--color-stroke-strong);
  }

  /* Outline marker variant — rings instead of filled. */
  [data-timeline="component"][data-timeline-outline="true"] [data-timeline-marker] {
    background: var(--color-canvas);
    box-shadow: 0 0 0 1.5px var(--color-fg);
    border: 2px solid var(--color-canvas);
  }

  /* Status variants override the marker fill. */
  [data-timeline-item][data-timeline-status="current"] [data-timeline-marker] {
    background: var(--color-intent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-intent) 25%, transparent);
  }
  [data-timeline-item][data-timeline-status="complete"] [data-timeline-marker] {
    background: var(--color-success);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-success) 50%, var(--color-stroke));
  }
  [data-timeline-item][data-timeline-status="future"] [data-timeline-marker] {
    background: var(--color-canvas);
    border-color: var(--color-canvas);
    box-shadow: 0 0 0 1px var(--color-stroke);
  }

  /* Date pill. */
  [data-timeline-date] {
    display: inline-block;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.25rem;
  }

  /* Title. */
  [data-timeline-title] {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.3;
  }

  /* Description. */
  [data-timeline-description] {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
  }

  /* Future status fades the whole row. */
  [data-timeline-item][data-timeline-status="future"] [data-timeline-title],
  [data-timeline-item][data-timeline-status="future"] [data-timeline-date],
  [data-timeline-item][data-timeline-status="future"] [data-timeline-description] {
    opacity: 0.55;
  }
</style>
