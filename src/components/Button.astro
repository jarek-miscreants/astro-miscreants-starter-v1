---
import { Icon } from "astro-icon/components";

interface Props {
  label?: string;
  variant?: "primary" | "secondary" | "tertiary";
  href?: string;
  type?: "button" | "submit" | "reset";
  target?: string;
  rel?: string;
  disabled?: boolean;
  withArrow?: boolean;
  arrowDirection?: "right" | "left";
  class?: string;
}

const {
  label = "Learn More",
  variant = "primary",
  href,
  type = "button",
  target,
  rel,
  disabled = false,
  withArrow = true,
  arrowDirection = "right",
  class: className,
} = Astro.props;

const Tag = href && !disabled ? "a" : "button";

const base =
  "group inline-flex items-center justify-center whitespace-nowrap font-medium text-sm h-10 px-4 gap-2 cursor-pointer " +
  "transition-colors outline-none " +
  "focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-bg " +
  "disabled:pointer-events-none disabled:opacity-50 " +
  "aria-disabled:pointer-events-none aria-disabled:opacity-50";

const variants = {
  primary:
    "bg-primary text-primary-foreground hover:bg-primary/90",
  secondary:
    "border border-border bg-transparent text-text hover:bg-accent hover:text-accent-foreground",
  tertiary:
    "bg-transparent text-text hover:bg-accent hover:text-accent-foreground",
};

const arrowName =
  arrowDirection === "left" ? "lucide:arrow-left" : "lucide:arrow-right";

// Auto-safety: if linking external with target=_blank, add noopener/noreferrer
// unless the caller explicitly provided rel.
const safeRel =
  target === "_blank" ? (rel ?? "noopener noreferrer") : rel;
---

<Tag
  href={Tag === "a" ? href : undefined}
  type={Tag === "button" ? type : undefined}
  target={Tag === "a" ? target : undefined}
  rel={Tag === "a" ? safeRel : undefined}
  disabled={Tag === "button" && disabled ? true : undefined}
  aria-disabled={disabled ? "true" : undefined}
  class:list={[base, variants[variant], className]}
>
  <span><slot>{label}</slot></span>

  {withArrow && (
    <span
      class="relative inline-block h-4 w-4 overflow-hidden shrink-0 motion-reduce:overflow-visible "
      aria-hidden="true"
    >
      <span
        class:list={[
          "absolute inset-0 transition-transform duration-300 ease-in-out motion-reduce:transition-none",
          arrowDirection === "right"
            ? "group-hover:translate-x-full"
            : "group-hover:-translate-x-full",
        ]}
      >
        <Icon name={arrowName} class="h-4 w-4" />
      </span>
      <span
        class:list={[
          "absolute inset-0 transition-transform duration-300 ease-in-out motion-reduce:hidden",
          arrowDirection === "right"
            ? "-translate-x-full group-hover:translate-x-0"
            : "translate-x-full group-hover:translate-x-0",
        ]}
      >
        <Icon name={arrowName} class="h-4 w-4" />
      </span>
    </span>
  )}
</Tag>
