---
// 1. Define the contract — what props this component accepts.
//    TypeScript will warn callers about typos and wrong types.
interface Props {
  variant?: "primary" | "secondary";
  border?: "all" | "y" | "x" | "none";
  class?: string;
}

// 2. Extract prop values from Astro.props.
//    Defaults are set here via `= "primary"`.
//    `class` is a JS reserved word, so alias it to `className`.
const { variant = "primary", border = "all", class: className } = Astro.props;

// 3. Variant lookup — maps each variant name to its Tailwind classes.
//    Add a new variant = add one line here + update the union type above.
const variantClasses = {
  primary: "",
  secondary: "",
};

// 4. Conditional prop lookup — same pattern, different dimension.
//    Keeps border logic out of the template.
const borderClasses = {
  all: "border border-stroke",
  y: "border-y border-stroke",
  x: "border-x border-stroke",
  none: "",
};

// 5. Check if a named slot has content (at build time).
//    Use this to conditionally render slots and adjust styling.
const hasMedia = Astro.slots.has("media");
---

<!-- 6. class:list combines base classes, variant classes, conditional classes,
     and any classes passed in from the parent via the `class` prop. -->
<div class:list={["", variantClasses[variant], borderClasses[border], hasMedia ? "pb-0" : "pb-8", className]}>
  <!-- 7. Default slot — content between <ComponentTemplate>...</ComponentTemplate> renders here. -->
  <slot />

  <!-- 8. Named slot — only renders if the caller passes content with slot="media".
       The hasMedia check prevents an empty wrapper from appearing in the DOM. -->
  {hasMedia && (
    <slot name="media" />
  )}
</div>

