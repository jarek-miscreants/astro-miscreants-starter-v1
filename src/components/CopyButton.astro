---
// CopyButton — small button that copies a string (or the text content of a
// referenced element) to the clipboard and shows momentary feedback. Useful
// on its own (next to inline tokens, snippets, share URLs) and as the copy
// affordance inside CodeBlock.
//
// Usage:
//   <CopyButton value="npm install astro" label="Copy install command" />
//   <CopyButton target="#my-snippet" />
//
// One of `value` or `target` must be provided.

interface Props {
  /** Literal string to copy. */
  value?: string;
  /** CSS selector for the element whose `.textContent` should be copied. */
  target?: string;
  /** Accessible label. Default "Copy". */
  label?: string;
  /** Feedback message shown briefly after a successful copy. Default "Copied". */
  copiedLabel?: string;
  /** Time in ms the feedback state is visible. Default 1500. */
  feedbackDuration?: number;
  class?: string;
}

const {
  value,
  target,
  label = "Copy",
  copiedLabel = "Copied",
  feedbackDuration = 1500,
  class: className,
} = Astro.props;
---

<button
  type="button"
  data-copy-button
  data-copy-value={value}
  data-copy-target={target}
  data-copy-feedback-duration={feedbackDuration}
  data-copy-state="idle"
  aria-label={label}
  class:list={["copy-button", className]}
>
  <span data-copy="icon-idle" aria-hidden="true">
    <slot name="icon-idle">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
    </slot>
  </span>
  <span data-copy="icon-copied" aria-hidden="true">
    <slot name="icon-copied">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12" />
      </svg>
    </slot>
  </span>
  <span data-copy="label-idle"><slot>{label}</slot></span>
  <span data-copy="label-copied">{copiedLabel}</span>
  <span data-copy="live" class="sr-only" aria-live="polite"></span>
</button>

<style is:global>
  [data-copy-button] {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  [data-copy-button] [data-copy="icon-copied"],
  [data-copy-button] [data-copy="label-copied"] {
    display: none;
  }
  [data-copy-button][data-copy-state="copied"] [data-copy="icon-idle"],
  [data-copy-button][data-copy-state="copied"] [data-copy="label-idle"] {
    display: none;
  }
  [data-copy-button][data-copy-state="copied"] [data-copy="icon-copied"],
  [data-copy-button][data-copy-state="copied"] [data-copy="label-copied"] {
    display: inline-flex;
  }

  /* Tailwind ships .sr-only, but in case this component is used outside
     the Tailwind preflight context, fall back to a manual visually-hidden. */
  [data-copy-button] [data-copy="live"]:not([class]) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const init = (btn: HTMLButtonElement) => {
    if (btn.dataset.scriptInitialized) return;
    btn.dataset.scriptInitialized = "true";

    const duration = Number(btn.getAttribute("data-copy-feedback-duration")) || 1500;
    const live = btn.querySelector<HTMLElement>('[data-copy="live"]');
    let resetTimer: ReturnType<typeof setTimeout> | null = null;

    btn.addEventListener("click", async () => {
      const literal = btn.getAttribute("data-copy-value");
      const targetSel = btn.getAttribute("data-copy-target");
      let toCopy = literal ?? "";

      if (!literal && targetSel) {
        const el = document.querySelector(targetSel);
        toCopy = el?.textContent?.trim() ?? "";
      }
      if (!toCopy) return;

      try {
        await navigator.clipboard.writeText(toCopy);
        btn.setAttribute("data-copy-state", "copied");
        if (live) live.textContent = "Copied to clipboard";
        if (resetTimer) clearTimeout(resetTimer);
        resetTimer = setTimeout(() => {
          btn.setAttribute("data-copy-state", "idle");
          if (live) live.textContent = "";
        }, duration);
      } catch {
        if (live) live.textContent = "Copy failed";
      }
    });
  };

  const initAll = () =>
    document.querySelectorAll<HTMLButtonElement>("[data-copy-button]").forEach(init);

  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>
