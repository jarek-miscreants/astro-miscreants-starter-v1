---
interface Props {
  title?: string;
  description?: string;
  border?: "all" | "y" | "x" | "none";
  class?: string;
  titleClass?: string;
  titleTag?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
}

const {
  title,
  description,
  border = "all",
  class: className = "",
  titleClass = "h3",
  titleTag: TitleTag = "h3",
} = Astro.props;

const borderClass = {
  all: "border border-stroke",
  y: "border-y border-stroke",
  x: "border-x border-stroke",
  none: "",
}[border];

const hasEyebrow = Astro.slots.has("eyebrow");
const hasMedia = Astro.slots.has("media");
const hasButton = Astro.slots.has("button");
---

<div
  class:list={[
    "relative px-4 pt-4 md:px-8 md:pt-8",
    hasMedia ? "pb-0" : "pb-8",
    borderClass,
    className,
  ]}
>
  <div class="flex flex-col gap-4">
    {hasEyebrow && (
      <div class="text-body-sm text-fg-muted">
        <slot name="eyebrow" />
      </div>
    )}
    {title && <TitleTag class={titleClass}>{title}</TitleTag>}
    {description && <p class="text-fg-muted">{description}</p>}
    <slot name="media" />
    {hasButton && <slot name="button" />}
  </div>
</div>
